#!/bin/bash
set -euo pipefail

exec > >(tee /var/log/observability-suite-bootstrap.log | logger -t observability-suite-bootstrap -s 2>/dev/console) 2>&1

echo "Starting observability suite bootstrap"

dnf install -y docker curl
systemctl enable --now docker
usermod -aG docker ec2-user || true

mkdir -p /usr/local/lib/docker/cli-plugins

if ! docker compose version >/dev/null 2>&1; then
  ARCH="$(uname -m)"
  case "$${ARCH}" in
    x86_64)
      COMPOSE_ARCH="x86_64"
      ;;
    aarch64|arm64)
      COMPOSE_ARCH="aarch64"
      ;;
    *)
      echo "Unsupported architecture for Docker Compose: $${ARCH}" >&2
      exit 1
      ;;
  esac

  COMPOSE_VERSION="v2.29.7"
  curl -fsSL "https://github.com/docker/compose/releases/download/$${COMPOSE_VERSION}/docker-compose-linux-$${COMPOSE_ARCH}" \
    -o /usr/local/lib/docker/cli-plugins/docker-compose
  chmod +x /usr/local/lib/docker/cli-plugins/docker-compose
fi

docker compose version

mkdir -p /opt/observability-suite/alloy
mkdir -p /opt/observability-suite/prometheus
mkdir -p /opt/observability-suite/loki
mkdir -p /opt/observability-suite/tempo
mkdir -p /opt/observability-suite/grafana/provisioning/datasources
mkdir -p /opt/observability-suite/grafana/provisioning/dashboards
mkdir -p /opt/observability-suite/grafana/dashboards

cat <<'EOF' | base64 -d > /opt/observability-suite/docker-compose.yml
${compose_b64}
EOF

cat <<'EOF' | base64 -d > /opt/observability-suite/alloy/config.alloy
${alloy_config_b64}
EOF

cat <<'EOF' | base64 -d > /opt/observability-suite/prometheus/prometheus.yml
${prometheus_config_b64}
EOF

cat <<'EOF' | base64 -d > /opt/observability-suite/loki/config.yml
${loki_config_b64}
EOF

cat <<'EOF' | base64 -d > /opt/observability-suite/tempo/config.yml
${tempo_config_b64}
EOF

cat <<'EOF' | base64 -d > /opt/observability-suite/grafana/provisioning/datasources/datasources.yml
${grafana_datasources_b64}
EOF

cat <<'EOF' | base64 -d > /opt/observability-suite/grafana/provisioning/dashboards/provider.yml
${grafana_dashboard_provider_b64}
EOF

cat <<'EOF' | base64 -d > /opt/observability-suite/grafana/dashboards/workshop-order-processing.json
${grafana_dashboard_b64}
EOF

docker compose -f /opt/observability-suite/docker-compose.yml pull
docker compose -f /opt/observability-suite/docker-compose.yml up -d

echo "Observability suite bootstrap completed"
